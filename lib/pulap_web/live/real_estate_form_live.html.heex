<div class="w-full max-w-xl mx-auto">
  <h1 class="text-2xl font-bold mb-4">New Real Estate</h1>
  <.live_component
    module={PulapWeb.RealEstateFormComponent}
    id="real-estate-form"
    changeset={@changeset}
    categories={@categories}
    types={@types}
    subtypes={@subtypes}
    selected_category={@selected_category}
    selected_type={@selected_type}
    selected_subtype={@selected_subtype}
    show_manual_coords={@show_manual_coords}
  />
</div>
