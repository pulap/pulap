<.header class="justify-center text-center">
  <span class="font-bold text-xl">Edit Permission {@permission.name}</span>
</.header>

<div class="flex justify-center">
  <div class="w-full max-w-xl">
    <.permission_form changeset={@changeset} action={~p"/permissions/#{@permission}"} />
  </div>
</div>
